    "This shows whether iOS thinks local protection is installed, starting, connected, or stopped.": {
      "comment": "Bug-report preview section purpose: VPN Status.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This shows whether iOS thinks local protection is installed, starting, connected, or stopped."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das zeigt, ob iOS den lokalen Schutz als installiert, startend, verbunden oder gestoppt einstuft."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto muestra si iOS considera que la protección local está instalada, iniciándose, conectada o detenida."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci indique si iOS considère que la protection locale est installée, en cours de démarrage, connectée ou arrêtée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra se per iOS la protezione locale risulta installata, in avvio, connessa o interrotta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS がローカル保護をインストール済み、起動中、接続済み、停止のどの状態と認識しているかを表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS가 로컬 보호를 설치됨, 시작 중, 연결됨 또는 중지됨 중 어떤 상태로 인식하는지 보여 줍니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso mostra se o iOS considera a proteção local como instalada, iniciando, conectada ou parada."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会显示 iOS 认为本地防护处于已安装、正在启动、已连接还是已停止的状态。"
