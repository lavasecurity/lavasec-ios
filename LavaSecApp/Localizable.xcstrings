    "Detailed activity is kept for 7 days — export to keep a copy.": {
      "comment": "Release app UI string. Keep product/legal terms from the glossary unchanged and review before final release.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Detaillierte Aktivität wird 7 Tage lang aufbewahrt – exportiere sie, um eine Kopie zu behalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Detailed activity is kept for 7 days — export to keep a copy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'activité détaillée est conservée 7 jours — exportez-la pour en garder une copie."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "詳細なアクティビティは 7 日間保存されます。控えを残すにはエクスポートしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "详细活动保留 7 天——导出可保留副本。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "詳細活動會保留 7 天——匯出即可留存副本。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La actividad detallada se conserva 7 días; exporta para guardar una copia."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "상세 활동은 7일간 보관돼요 — 사본을 남기려면 내보내세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A atividade detalhada é mantida por 7 dias — exporte para guardar uma cópia."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'attività dettagliata viene conservata per 7 giorni — esporta per tenerne una copia."
          }
        }
      }
    },
    "Detailed activity stays on this phone for 7 days and is sent to us only if you include it in a bug report.": {
      "comment": "Release app UI string. Keep product/legal terms from the glossary unchanged and review before final release.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Detaillierte Aktivität bleibt 7 Tage lang auf diesem Telefon und wird nur gesendet, wenn du sie einem Fehlerbericht beifügst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Detailed activity stays on this phone for 7 days and is sent to us only if you include it in a bug report."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’activité détaillée reste sur ce téléphone pendant 7 jours et ne nous est envoyée que si vous la joignez à un rapport de bug."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "詳細なアクティビティはこのスマートフォンに7日間保存され、バグレポートに含めた場合にのみ送信されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "详细活动会在这台手机上保留 7 天，只有你把它附在错误报告里时才会发送给我们。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "詳細活動會在這台手機上保留 7 天，只有在你把它加入錯誤回報時才會傳送給我們。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La actividad detallada permanece en este teléfono durante 7 días y solo nos llega si la incluyes en un informe de error."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "상세 활동은 이 휴대폰에 7일간 보관되며, 버그 신고에 포함할 때만 전송돼요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A atividade detalhada fica neste telefone por 7 dias e só é enviada para nós se você a incluir em um relatório de problema."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'attività dettagliata resta su questo telefono per 7 giorni e ci viene inviata solo se la includi in una segnalazione."
          }
        }
      }
    },
