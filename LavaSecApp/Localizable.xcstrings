    "Lava could not reach the source catalog. Check your connection and try again.": {
      "comment": "Prepare-failure reason: catalog unreachable.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava konnte den Quellenkatalog nicht erreichen. Prüfe deine Verbindung und versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava could not reach the source catalog. Check your connection and try again."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava n'a pas pu accéder au catalogue source. Vérifiez votre connexion et réessayez."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava はソースカタログに接続できませんでした。接続を確認してもう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava 无法连接到来源目录。请检查你的连接并重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava 無法連接到來源目錄。請檢查你的連線並重試。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava no ha podido acceder al catálogo de origen. Comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava가 소스 카탈로그에 연결하지 못했어요. 연결을 확인하고 다시 시도하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A Lava não conseguiu acessar o catálogo de origem. Verifique sua conexão e tente de novo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava non è riuscito a raggiungere il catalogo delle fonti. Controlla la connessione e riprova."
          }
        }
      }
    },
