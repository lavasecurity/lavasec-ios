    "In Shortcuts, create an automation for a time, place, or event.": {
      "comment": "Automation step 1 in the auto-switch how-to. 'Shortcuts' is the iOS app name.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle in Kurzbefehle eine Automation für eine Zeit, einen Ort oder ein Ereignis."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In Shortcuts, create an automation for a time, place, or event."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En Atajos, crea una automatización para una hora, un lugar o un evento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dans Raccourcis, créez une automatisation pour une heure, un lieu ou un événement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "In Comandi rapidi, crea un’automazione per un orario, un luogo o un evento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「ショートカット」で、時刻・場所・イベントのオートメーションを作成します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단축어에서 시간, 위치 또는 이벤트 오토메이션을 만드세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Em Atalhos, crie uma automação para um horário, local ou evento."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在快捷指令中，为时间、地点或事件创建一个自动化。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在捷徑中，為時間、地點或事件建立一個自動化操作。"
          }
        }
      }
    },
