        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したリゾルバーが一時的に利用できないため、暗号化 DNS のバックアップでフィルタリングを継続しています"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "DNS 공급자를 잠시 사용할 수 없어 암호화된 DNS 백업으로 필터링이 켜져 있어요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A filtragem está ativa usando o backup de DNS criptografado porque o seu provedor de DNS está indisponível por um instante"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
