    "Apply makes this the filter in effect. View & edit opens it to read or edit without switching.": {
      "comment": "Localization-gap backfill (was hardcoded in FiltersView.swift).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apply makes this the filter in effect. View & edit opens it to read or edit without switching."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Anwenden“ macht diesen Filter aktiv. „Ansehen & bearbeiten“ öffnet ihn zum Lesen oder Bearbeiten, ohne zu wechseln."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplicar lo convierte en el filtro activo. Ver y editar lo abre para leerlo o editarlo sin cambiar de filtro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Appliquer » en fait le filtre actif. « Voir et modifier » l’ouvre pour le consulter ou le modifier sans changer de filtre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Applica rende questo il filtro attivo. Visualizza e modifica lo apre per leggerlo o modificarlo senza cambiarlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「適用」でこれを有効なフィルターにします。「表示・編集」では切り替えずに内容を確認・編集できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "「적용」하면 이 필터가 적용돼요. 「보기 및 편집」은 전환하지 않고 열어서 보거나 편집해요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplicar torna este o filtro em uso. Ver e editar abre o filtro para ler ou editar sem trocar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“应用”会让这个筛选器生效。“查看与编辑”则只打开它来阅读或修改，而不切换。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「套用」會讓這個篩選器生效。「檢視與編輯」則會打開它來閱讀或修改，不會切換。"
          }
        }
      }
    },
