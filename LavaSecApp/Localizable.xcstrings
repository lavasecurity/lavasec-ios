    "Thank you, Lava will look into this": {
      "comment": "Feedback confirmation title shown after a report is submitted without a follow-up email.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Danke, Lava wird sich das ansehen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thank you, Lava will look into this"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Merci, Lava va examiner ça"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ありがとうございます。Lava が確認します"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "谢谢，岩酱会查看"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "謝謝，岩醬會查看"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gracias, Lava lo revisará"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "감사해요, Lava가 살펴볼게요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Obrigado, a Lava vai analisar isso"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Grazie, Lava ci darà un'occhiata"
          }
        }
      }
    },
    "Thank you, Lava will look into this and reach out if needed": {
      "comment": "Feedback confirmation title shown after a report is submitted with a follow-up email.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Danke, Lava wird sich das ansehen und sich bei Bedarf melden"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thank you, Lava will look into this and reach out if needed"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Merci, Lava va examiner ça et vous contactera si besoin"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ありがとうございます。Lava が確認し、必要に応じてご連絡します"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "谢谢，岩酱会查看，并在需要时联系你"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "謝謝，岩醬會查看，並在需要時聯絡你"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gracias, Lava lo revisará y se pondrá en contacto si es necesario"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "감사해요, Lava가 살펴보고 필요하면 연락드릴게요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Obrigado, a Lava vai analisar isso e entrar em contato se precisar"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Grazie, Lava ci darà un'occhiata e ti contatterà se necessario"
          }
        }
      }
    },
