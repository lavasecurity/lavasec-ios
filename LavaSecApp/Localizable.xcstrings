            "state": "translated",
            "value": "This includes recent app, VPN, and tunnel handling events. It does not include DNS requests."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das umfasst aktuelle App-, VPN- und Tunnel-Ereignisse. DNS-Anfragen sind nicht enthalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto incluye eventos recientes de gestión de la app, la VPN y el túnel. No incluye solicitudes de DNS."
          }
        },
        "fr": {
