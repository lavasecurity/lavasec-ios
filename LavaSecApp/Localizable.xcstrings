    "Malicious domains are the hot spots. Your phone can step around them before apps and websites connect." : {
      "comment" : "Release app UI string. Keep placeholders and product names intact.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schädliche Domains sind die Gefahrenstellen. Dein Smartphone kann ihnen ausweichen, bevor Apps und Websites eine Verbindung aufbauen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Malicious domains are the hot spots. Your phone can step around them before apps and websites connect."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les domaines malveillants, c'est là que ça chauffe. Votre téléphone peut les éviter avant que les apps et les sites web s'y connectent."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "悪意のあるドメインは、ネット上の危険なスポットです。アプリやウェブサイトが接続する前に、スマートフォンがそこを避けてくれます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恶意域名就像滚烫的岩浆。App 和网站连接前，你的手机可以先帮你绕开它们。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
