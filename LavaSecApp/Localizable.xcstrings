    "Lava waits 30 minutes after your last settings change before it tries an automatic upload.": {
      "comment": "Footer under the Automatic Backup toggle in Account & Backup settings.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava waits 30 minutes after your last settings change before it tries an automatic upload."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava wartet nach deiner letzten Einstellungsänderung 30 Minuten, bevor es einen automatischen Upload versucht."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava espera 30 minutos desde tu último cambio de ajustes antes de intentar una subida automática."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava attend 30 minutes après ta dernière modification des réglages avant de tenter un envoi automatique."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava attende 30 minuti dall'ultima modifica delle impostazioni prima di tentare un caricamento automatico."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava は設定の最後の変更から30分待ってから、自動アップロードを試みます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava는 마지막으로 설정을 변경한 후 30분을 기다린 다음 자동 업로드를 시도합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Lava aguarda 30 minutos após sua última alteração de ajustes antes de tentar um envio automático."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava 会在你最后一次更改设置 30 分钟后，才尝试自动上传。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
