    "Spaces and capitalization do not matter. Press space to jump to the next word.": {
      "comment": "Localization-gap backfill (was hardcoded in BackupRestoreView.swift).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Spaces and capitalization don't matter. Press space to jump to the next word."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Leerzeichen und Groß-/Kleinschreibung spielen keine Rolle. Drücke die Leertaste, um zum nächsten Wort zu springen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los espacios y las mayúsculas no importan. Pulsa espacio para saltar a la siguiente palabra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les espaces et les majuscules n'ont pas d'importance. Appuyez sur Espace pour passer au mot suivant."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Spazi e maiuscole non contano. Premi spazio per passare alla parola successiva."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スペースや大文字・小文字は問いません。スペースキーで次の単語に移動できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "띄어쓰기와 대소문자는 상관없어요. 스페이스를 누르면 다음 단어로 넘어가요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Espaços e maiúsculas não importam. Pressione espaço para ir à próxima palavra."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "空格和大小写都不影响。按空格键跳到下一个词。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "空格和大小寫都沒關係。按空白鍵即可跳到下一個字。"
          }
        }
      }
    },
