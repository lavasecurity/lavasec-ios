    "Pick a filter for a Focus and Lava switches to it on its own whenever that Focus turns on — no taps needed.": {
      "comment": "Explainer in the Focus auto-switch how-to: links a saved filter to an iOS Focus. 'Lava' is the app name (keep untranslated).",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Weise einem Fokus einen Filter zu, und Lava wechselt von selbst dorthin, sobald dieser Fokus aktiv wird – ganz ohne Tippen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick a filter for a Focus and Lava switches to it on its own whenever that Focus turns on — no taps needed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Asigna un filtro a una Concentración y Lava cambiará a él automáticamente cada vez que esa Concentración se active, sin que toques nada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Associez un filtre à une Concentration et Lava bascule dessus tout seul dès que cette Concentration s’active — sans rien toucher."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Assegna un filtro a una Full Immersion e Lava passa a quel filtro da solo ogni volta che la Full Immersion si attiva, senza toccare nulla."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "集中モードにフィルターを設定すると、その集中モードがオンになるたびにLavaが自動で切り替えます。タップは不要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "집중 모드에 필터를 지정하면 해당 집중 모드가 켜질 때마다 Lava가 알아서 전환합니다. 탭할 필요가 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha um filtro para um Foco e o Lava muda para ele sozinho sempre que esse Foco for ativado — sem precisar tocar em nada."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为某个专注模式选择一个过滤器，每当该专注模式开启时，Lava 都会自动切换，无需手动操作。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為某個專注模式選擇一個篩選器，每當該專注模式開啟時，Lava 都會自動切換，無需手動操作。"
          }
        }
      }
    },
    "Pick how Lava looks and feels. None of these change how it protects you, so try anything.": {
      "comment": "Customization screen footer reassuring that appearance changes are safe.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle, wie Lava aussieht und sich anfühlt. Nichts davon ändert, wie es dich schützt, also probier ruhig alles aus."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick how Lava looks and feels. None of these change how it protects you, so try anything."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige el aspecto y la sensación de Lava. Nada de esto cambia cómo te protege, así que prueba lo que quieras."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez l'apparence et l'ambiance de Lava. Rien de tout cela ne change la façon dont il vous protège, alors essayez librement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli l'aspetto e lo stile di Lava. Nessuna di queste opzioni cambia il modo in cui ti protegge, quindi prova quello che vuoi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava の見た目や雰囲気を選びましょう。どれも保護のしかたには影響しないので、自由に試してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava의 모습과 느낌을 골라 보세요. 이 중 어떤 것도 당신을 보호하는 방식을 바꾸지 않으니, 무엇이든 마음껏 시도해 보세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha a aparência e o estilo da Lava. Nada disso muda como ela protege você, então experimente à vontade."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "挑选 Lava 的外观与感觉。这些都不会改变它保护你的方式,所以尽管放心尝试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "挑選 Lava 的外觀與感覺。這些都不會改變它保護你的方式,所以儘管放心嘗試。"
          }
        }
      }
    },
