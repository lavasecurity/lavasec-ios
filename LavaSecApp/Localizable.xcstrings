    },
    "This replaces your blocklists and blocked domains. Your allowed exceptions and DNS choice stay put.": {
      "comment": "Footer caution on the import screen. Keep 'DNS' untranslated; 'blocklists'/'blocked domains'/'allowed exceptions' match catalog.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das ersetzt deine Blocklisten und blockierten Domains. Deine erlaubten Ausnahmen und deine DNS-Auswahl bleiben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This replaces your blocklists and blocked domains. Your allowed exceptions and DNS choice stay put."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto reemplaza tus listas de bloqueo y dominios bloqueados. Tus excepciones permitidas y tu elección de DNS se quedan igual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela remplace vos listes de blocage et domaines bloqués. Vos exceptions autorisées et votre choix de DNS restent en place."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo sostituisce le tue liste di blocco e i domini bloccati. Le tue eccezioni consentite e la scelta del DNS restano."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブロックリストとブロック済みドメインが置き換わります。許可した例外と DNS の選択はそのまま残ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "차단 목록과 차단 도메인이 바뀌어요. 허용 예외와 DNS 선택은 그대로 남아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto substitui as suas listas de bloqueio e os domínios bloqueados. As suas exceções liberadas e a escolha de DNS continuam."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会替换你的拦截列表和已拦截域名。允许的例外和 DNS 选择保持不变。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這會取代你的封鎖清單和已封鎖網域。你的允許例外和 DNS 選擇會保留。"
          }
        }
      }
    },
    "Tip: put the Focus on a schedule to switch filters automatically by time of day.": {
      "comment": "Tip in the Focus filter how-to about scheduling an iOS Focus.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tipp: Plane den Fokus zeitlich, um Filter automatisch nach Tageszeit zu wechseln."
          }
        },
        "en": {
