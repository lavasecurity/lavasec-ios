    "Stay covered if your device's DNS can't be reached after a network change.": {
      "comment": "Localization-gap backfill (wrapper-localized; was hardcoded in OnboardingFlowView.swift).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay covered if your device's DNS can't be reached after a network change."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bleib geschützt, falls das DNS deines Geräts nach einem Netzwerkwechsel nicht erreichbar ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigue protegido si no se puede acceder al DNS de tu dispositivo tras un cambio de red."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Restez protégé si le DNS de votre appareil devient injoignable après un changement de réseau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Resti protetto se il DNS del dispositivo non è raggiungibile dopo un cambio di rete."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワークの切り替え後に端末の DNS に接続できなくなっても、保護を継続します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "네트워크가 바뀐 뒤 기기 DNS에 연결할 수 없어도 계속 보호받아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Continue protegido se o DNS do dispositivo ficar inacessível após uma mudança de rede."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "网络切换后，即便设备的 DNS 无法访问，也能持续受到保护。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "網路變更後若無法連上裝置的 DNS，仍能維持防護。"
          }
        }
      }
    },
