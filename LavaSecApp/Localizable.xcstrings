          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer la copie de sauvegarde en ligne"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina la copia di backup online"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンラインバックアップを削除"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "온라인 백업 사본 삭제"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Excluir a cópia de backup on-line"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除在线备份副本"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除線上備份副本"
          }
        }
      }
    },
    "Delete online backup copy removes the server copy but keeps backups on. Turn off & delete backup stops them too. Either way, the online copy can't be recovered.": {
      "comment": "Account & Backup: caveat under the two destructive backup options, disambiguating 'Delete online backup copy' (keeps backup on this device) from 'Turn off & delete backup' (stops backups too).",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Online-Backup-Kopie löschen“ entfernt die Server-Kopie, lässt Backups aber an. „Backup ausschalten und löschen“ stoppt sie ganz. In beiden Fällen ist die Online-Kopie weg."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete online backup copy removes the server copy but keeps backups on. Turn off & delete backup stops them too. Either way, the online copy can't be recovered."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«Eliminar la copia en línea» borra la copia del servidor, pero mantiene las copias de seguridad activas. «Desactivar y eliminar» también las detiene. En ambos casos, la copia en línea no se puede recuperar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Supprimer la copie en ligne » retire la copie du serveur mais laisse la sauvegarde active. « Désactiver et supprimer » l'arrête aussi. Dans les deux cas, la copie en ligne est irrécupérable."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "«Elimina la copia di backup online» rimuove la copia sui server ma lascia attivo il backup. «Disattiva ed elimina il backup» ferma anche quello. In ogni caso, la copia online non si può recuperare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「オンラインバックアップのコピーを削除」はサーバー上のコピーだけ消し、バックアップは続きます。「バックアップをオフにして削除」は両方止めます。どちらもオンラインのコピーは復元できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "「온라인 백업 사본 삭제」는 서버 사본만 지우고 백업은 켜진 채로 둬요. 「백업 끄고 삭제」는 백업도 멈춰요. 어느 쪽이든 온라인 사본은 복구할 수 없어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Excluir a cópia de backup on-line\" apaga a cópia do servidor, mas mantém o backup ativo. \"Desativar e excluir o backup\" também para com eles. Em ambos os casos, a cópia on-line não pode ser recuperada."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“删除在线备份副本”只删服务器上的副本,备份仍开着;“关闭并删除备份”会一并停止备份。两种方式都无法找回在线副本。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「刪除線上備份副本」會移除伺服器上的副本，但備份仍開著。「關閉並刪除備份」則會一併停止。兩種方式，線上副本都無法復原。"
          }
        }
      }
    },
