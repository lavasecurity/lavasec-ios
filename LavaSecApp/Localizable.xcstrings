    "Everything unlocks on this iPhone — nothing is sent to us. Your unlock key stays in the iPhone's secure keychain.": {
      "comment": "Restore/backup footer explaining on-device unlock and keychain storage.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alles wird auf diesem iPhone entsperrt – nichts geht an uns. Dein Entsperrschlüssel bleibt im sicheren Schlüsselbund des iPhones."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Everything unlocks on this iPhone — nothing is sent to us. Your unlock key stays in the iPhone's secure keychain."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo se desbloquea en este iPhone; no se nos envía nada. Tu clave de desbloqueo se queda en el llavero seguro del iPhone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout se déverrouille sur cet iPhone — rien ne nous est envoyé. Votre clé de déverrouillage reste dans le trousseau sécurisé de l'iPhone."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutto si sblocca su questo iPhone — non ci viene inviato nulla. La tua chiave di sblocco resta nel portachiavi sicuro dell'iPhone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "解除はすべてこの iPhone 上で行われ、当社には何も送信されません。解除キーは iPhone の安全なキーチェーンに保管されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 게 이 iPhone에서 풀려요. 우리에게 보내는 건 없어요. 잠금 해제 키는 iPhone의 안전한 키체인에 남아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tudo é desbloqueado neste iPhone — nada é enviado para nós. A sua chave de desbloqueio fica no porta-chaves seguro do iPhone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一切都在这部 iPhone 上解锁——不会发给我们。你的解锁密钥留在 iPhone 的安全钥匙串里。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一切都在這支 iPhone 上解鎖——不會傳送給我們。你的解鎖金鑰會留在 iPhone 的安全鑰匙圈裡。"
          }
        }
      }
    },
