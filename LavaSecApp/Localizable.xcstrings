      }
    },
    "Optional (iOS 18+). Saved in your password manager to restore on a new device. Your phone makes the key itself, so Lava still can't read your backup.": {
      "comment": "Backup/Passkey option footer; note iOS 18+ and on-device key generation.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional (iOS 18+). Wird in deinem Passwort-Manager gespeichert, um auf einem neuen Gerät wiederherzustellen. Dein Telefon erstellt den Schlüssel selbst, also kann Lava dein Backup trotzdem nicht lesen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional (iOS 18+). Saved in your password manager to restore on a new device. Your phone makes the key itself, so Lava still can't read your backup."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Opcional (iOS 18+). Se guarda en tu gestor de contraseñas para restaurar en un dispositivo nuevo. Tu teléfono crea la clave él mismo, así que Lava sigue sin poder leer tu copia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Facultatif (iOS 18+). Enregistré dans votre gestionnaire de mots de passe pour restaurer sur un nouvel appareil. Votre téléphone crée la clé lui-même, donc Lava ne peut toujours pas lire votre sauvegarde."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Facoltativo (iOS 18+). Salvato nel tuo gestore di password per ripristinare su un nuovo dispositivo. La chiave la crea il telefono, quindi Lava non può leggere il tuo backup."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "任意 (iOS 18+)。パスワードマネージャーに保存し、新しい端末での復元に使います。キーはスマホ自身が作るので、Lava はバックアップを読めません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택 사항 (iOS 18+). 비밀번호 관리자에 저장돼 새 기기에서 복원할 때 써요. 키는 휴대폰이 직접 만들어 Lava는 백업을 못 읽어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Opcional (iOS 18+). Salvo no seu gerenciador de senhas para restaurar num novo aparelho. O seu telefone cria a chave sozinho, então a Lava continua sem ler o seu backup."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选 (iOS 18+)。存到你的密码管理器,用于在新设备恢复。密钥由你手机自己生成,所以 Lava 仍读不到你的备份。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選用 (iOS 18+)。存在你的密碼管理工具，用來在新裝置還原。金鑰由手機自己產生，所以 Lava 還是讀不到你的備份。"
          }
        }
      }
    },
    "Optional diagnostics include anonymized Lava Data like VPN status, network logs, and filter snapshot. They help the Lava team better investigate what went wrong.": {
      "comment": "Feedback form diagnostic-data explanation. Keep Lava and VPN unchanged.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optionale Diagnosedaten enthalten anonymisierte Lava-Daten wie VPN-Status, Netzwerkprotokolle und einen Filter-Snapshot. Sie helfen dem Lava-Team, besser zu verstehen, was schiefgelaufen ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional diagnostics include anonymized Lava Data like VPN status, network logs, and filter snapshot. They help the Lava team better investigate what went wrong."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les diagnostics facultatifs incluent des données Lava anonymisées comme l’état du VPN, les journaux réseau et un aperçu des filtres. Ils aident l’équipe Lava à mieux comprendre ce qui s’est passé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "任意の診断には、VPN の状態、ネットワークログ、フィルタースナップショットなどの匿名化された Lava データが含まれます。Lava チームが問題の原因をより詳しく調査するのに役立ちます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选诊断包括匿名化的 Lava Security 数据，例如 VPN 状态、网络日志和过滤器快照。这有助于 Lava Security 团队更好地调查出了什么问题。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選用診斷包含匿名化的 Lava Security 資料，例如 VPN 狀態、網路記錄和篩選器快照。這有助於 Lava Security 團隊更好地調查出了什麼問題。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los diagnósticos opcionales incluyen datos de Lava anonimizados, como el estado de la VPN, los registros de red y la instantánea del filtro. Ayudan al equipo de Lava a investigar mejor qué ha ocurrido."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택 진단 정보에는 VPN 상태, 네트워크 로그, 필터 스냅샷 같은 익명화된 Lava 데이터가 포함돼요. Lava 팀이 문제를 더 잘 살펴보는 데 도움이 돼요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os diagnósticos opcionais incluem dados anônimos da Lava, como status da VPN, registros de rede e resumo do filtro. Eles ajudam a equipe da Lava a investigar melhor o que aconteceu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La diagnostica facoltativa include dati Lava anonimizzati come lo stato della VPN, i registri di rete e l'istantanea del filtro. Aiutano il team di Lava a capire meglio cosa è andato storto."
          }
        }
      }
    },
