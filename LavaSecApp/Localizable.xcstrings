    "Lava uses a local filter to block your phone's access to unwanted sites.": {
      "comment": "Filters tab: illustration caption (singular: one local filter).",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava verwendet einen lokalen Filter, um den Zugriff deines Telefons auf unerwünschte Websites zu blockieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava uses a local filter to block your phone's access to unwanted sites."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava utilise un filtre local pour bloquer l'accès de votre téléphone aux sites indésirables."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava はローカルフィルターを使って、不要なサイトへのアクセスをブロックします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava 使用本地过滤器阻止你的手机访问不需要的网站。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava 使用本機篩選器阻止你的手機存取不需要的網站。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava usa un filtro local para bloquear el acceso de tu teléfono a sitios no deseados."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava는 로컬 필터로 휴대폰이 원치 않는 사이트에 접속하지 못하게 막아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A Lava usa um filtro local para bloquear o acesso do seu telefone a sites indesejados."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava usa un filtro locale per bloccare l'accesso del tuo telefono ai siti indesiderati."
          }
        }
      }
    },
