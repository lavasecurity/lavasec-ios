        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "최근 앱, VPN, 터널 처리 이벤트가 포함됩니다. DNS 요청은 포함되지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso inclui eventos recentes de tratamento do app, da VPN e do túnel. Não inclui as solicitações de DNS."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
