    "Account login is only needed for encrypted backup upload, support history, or paid account management.": {
      "comment": "Localization-gap backfill (wrapper-localized; was hardcoded in SettingsView.swift).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Account login is only needed for encrypted backup upload, support history, or paid account management."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Anmeldung brauchst du nur für verschlüsselte Backups, den Support-Verlauf oder die Verwaltung eines kostenpflichtigen Kontos."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo necesitas iniciar sesión para subir una copia cifrada, ver tu historial de soporte o gestionar una cuenta de pago."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La connexion à un compte n'est nécessaire que pour l'envoi de sauvegardes chiffrées, l'historique du support ou la gestion d'un compte payant."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accesso all'account serve solo per caricare il backup cifrato, consultare la cronologia dell'assistenza o gestire un account a pagamento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウントログインが必要なのは、暗号化バックアップのアップロード、サポート履歴、有料アカウントの管理のときだけです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계정 로그인은 암호화 백업 업로드, 지원 기록, 유료 계정 관리에만 필요해요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O login só é necessário para enviar o backup criptografado, ver o histórico de suporte ou gerenciar uma conta paga."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只有上传加密备份、查看支持记录或管理付费账户时才需要登录账户。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
