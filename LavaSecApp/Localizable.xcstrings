    "Alerts when protection needs your help to reconnect on a network.": {
      "comment": "Customization → Notifications: helper text for the Connection updates toggle.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Alerts when protection needs your help to reconnect on a network."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワークでの再接続に操作が必要なときにお知らせします。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當保護需要你協助才能在網路上重新連線時提醒你。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当保护需要你协助以在网络上重新连接时提醒你。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warnt dich, wenn der Schutz deine Hilfe braucht, um sich erneut mit einem Netzwerk zu verbinden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous alerte lorsque la protection a besoin de vous pour se reconnecter à un réseau."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te avisa cuando la protección necesita tu ayuda para reconectarse a una red."
          }
        },
        "ko": {
          "stringUnit": {
