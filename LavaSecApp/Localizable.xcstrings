    "Lifecycle entries use safe event names and counters. Recent DNS and domain events are not included.": {
      "comment": "Localization-gap backfill (wrapper-localized; was hardcoded in SettingsView.swift).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lifecycle entries use safe event names and counters. Recent DNS and domain events are not included."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lebenszyklus-Einträge nutzen sichere Ereignisnamen und Zähler. Aktuelle DNS- und Domain-Ereignisse sind nicht enthalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las entradas del ciclo de vida usan nombres de evento y contadores seguros. No se incluyen los eventos recientes de DNS ni de dominios."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les entrées de cycle de vie utilisent des noms d'événements et des compteurs sans danger. Les événements DNS et de domaine récents ne sont pas inclus."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le voci del ciclo di vita usano nomi di eventi e contatori sicuri. Gli eventi DNS e di dominio recenti non sono inclusi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライフサイクルの記録には、安全なイベント名とカウンターだけを使います。最近の DNS やドメインのイベントは含まれません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수명 주기 항목은 안전한 이벤트 이름과 카운터만 사용해요. 최근 DNS 및 도메인 이벤트는 포함되지 않아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os registros de ciclo de vida usam nomes de eventos e contadores seguros. Eventos recentes de DNS e domínios não são incluídos."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "生命周期记录仅使用安全的事件名称和计数。不包含近期的 DNS 和域名事件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "生命週期項目只記錄安全的事件名稱與計數，不包含近期的 DNS 與網域事件。"
          }
        }
      }
    },
