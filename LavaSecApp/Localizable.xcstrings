    " to Lava Security Plus to bring your own list": {
      "comment": "Bring-your-own-list upgrade fragment rendered in gray after a bold \"Upgrade\" (FiltersView). Keep \"Lava Security Plus\" unchanged; preserve the leading space.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": " auf Lava Security Plus, um deinen eigenen Filter mitzubringen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": " to Lava Security Plus to bring your own filter"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": " Lava Security Plus pour utiliser votre propre filtre"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "して Lava Security Plus で独自のリストを使う"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": " 到 Lava Security Plus，即可使用你自己的列表"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "到 Lava Security Plus 即可帶入你自己的清單"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": " a Lava Security Plus para usar tu propia lista"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "하고 Lava Security Plus로 업그레이드해 내 필터를 가져오세요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": " para o Lava Security Plus e use o seu próprio filtro"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": " a Lava Security Plus per usare il tuo filtro"
          }
        }
      }
    },
    " to use DNS over HTTPS, TLS and QUIC": {
      "comment": "Release app UI string fragment. Preserve the leading space and keep DNS, HTTPS, TLS, and QUIC unchanged.",
      "extractionState": "manual",
      "localizations": {
