    "Allow camera access in Settings to scan a QR code — or tap back and enter the code instead.": {
      "comment": "Localization-gap backfill (was hardcoded in ShareableFiltersUI.swift).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow camera access in Settings to scan a QR code, or tap Back and enter the code instead."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaube den Kamerazugriff in den Einstellungen, um einen QR-Code zu scannen – oder tippe auf Zurück und gib den Code ein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite el acceso a la cámara en Ajustes para escanear un código QR, o toca Atrás e introduce el código a mano."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorisez l'accès à l'appareil photo dans Réglages pour scanner un code QR, ou touchez Retour et saisissez le code à la place."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Consenti l'accesso alla fotocamera in Impostazioni per scansionare un codice QR, oppure tocca Indietro e inserisci il codice manualmente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "QR コードを読み取るには「設定」でカメラへのアクセスを許可してください。または「戻る」をタップしてコードを直接入力できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "QR 코드를 스캔하려면 설정에서 카메라 접근을 허용하세요. 또는 뒤로 가서 코드를 직접 입력해도 돼요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Libere o acesso à câmera nos Ajustes para ler um QR code, ou toque em Voltar e digite o código."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在「设置」中允许访问相机以扫描 QR 码，或点按返回后手动输入代码。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在「設定」中允許相機存取以掃描 QR code，或點「返回」改用代碼輸入。"
          }
        }
      }
    },
