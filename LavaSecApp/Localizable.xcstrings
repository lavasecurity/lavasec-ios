    "Keep Lava protecting you to unlock more Guards, or [**Upgrade**](lavasecurity://settings/upgrade) to unlock them all.": {
      "comment": "Localization-gap backfill (was hardcoded in SettingsView.swift).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep Lava protecting you to unlock more Guards, or [**Upgrade**](lavasecurity://settings/upgrade) to unlock them all."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lass Lava dich weiter schützen, um mehr Guards freizuschalten, oder [**upgrade**](lavasecurity://settings/upgrade), um alle freizuschalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén Lava protegiéndote para desbloquear más Guards, o [**mejora tu plan**](lavasecurity://settings/upgrade) para desbloquearlos todos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gardez Lava active pour débloquer plus de Guards, ou [**Passez à la version supérieure**](lavasecurity://settings/upgrade) pour tous les débloquer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni attiva la protezione di Lava per sbloccare altri Guard, oppure [**passa a un piano superiore**](lavasecurity://settings/upgrade) per sbloccarli tutti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava で保護を続けるとガードがさらに解放されます。すべて解放するには [**アップグレード**](lavasecurity://settings/upgrade) してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava의 보호를 계속 켜 두면 Guard를 더 잠금 해제할 수 있어요. 모두 한 번에 풀려면 [**업그레이드**](lavasecurity://settings/upgrade)하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha a Lava protegendo você para desbloquear mais Guards, ou [**Faça upgrade**](lavasecurity://settings/upgrade) para desbloquear todos."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "持续让 Lava 保护你可解锁更多 Guard，或[**升级**](lavasecurity://settings/upgrade)一次全部解锁。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "持續讓 Lava 保護你即可解鎖更多 Guard，或[**升級**](lavasecurity://settings/upgrade)一次全部解鎖。"
          }
        }
      }
    },
    "Keep Lava protecting you to unlock this Guard.": {
