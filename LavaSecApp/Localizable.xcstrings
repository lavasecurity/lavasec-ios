    "Previous filters are still active. Lava could not reach the source catalog. Check your connection and try again.": {
      "comment": "Release app UI string or runtime format. Preserve placeholders and review before final release.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
