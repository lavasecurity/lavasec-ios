        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "不足・古い・正しくコンパイルされていないフィルターリストの調査に役立ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "누락되었거나 오래되었거나 잘못 컴파일된 필터 목록을 진단하는 데 도움이 돼요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso ajuda a depurar listas de filtros ausentes, desatualizadas ou compiladas incorretamente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这有助于排查缺失、过期或编译有误的筛选器列表。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這有助於排查缺失、過期或編譯有誤的篩選器清單。"
          }
        }
      }
    },
    "This helps reproduce bugs tied to a specific app build, iOS version, or device family.": {
