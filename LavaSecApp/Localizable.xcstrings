    "Bring in a setup someone shared. Add it as a new filter, or replace one of yours — you choose after previewing it.": {
      "comment": "Localization-gap backfill (wrapper-localized; was hardcoded in ShareableFiltersUI.swift).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring in a setup someone shared. Add it as a new filter, or replace one of yours — you choose after previewing it."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hol dir eine geteilte Konfiguration. Füg sie als neuen Filter hinzu oder ersetze einen deiner Filter – du entscheidest nach der Vorschau."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa una configuración que alguien ha compartido. Añádela como un nuevo filtro o reemplaza uno de los tuyos; tú decides después de verla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Importez une configuration partagée. Ajoutez-la comme nouveau filtre ou remplacez l'un des vôtres — vous choisissez après l'avoir prévisualisée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa una configurazione condivisa da qualcuno. Aggiungila come nuovo filtro o sostituisci uno dei tuoi: scegli dopo l'anteprima."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "誰かが共有した設定を取り込みます。新しいフィルターとして追加するか、既存のものを置き換えるかは、プレビューしてから選べます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 사람이 공유한 설정을 가져와요. 새 필터로 추가하거나 기존 필터를 교체할 수 있고, 미리 본 뒤에 선택해요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Traga uma configuração que alguém compartilhou. Adicione como um novo filtro ou substitua um dos seus — você decide depois de visualizá-la."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导入他人分享的配置。可作为新筛选器添加，或替换你现有的某个筛选器——预览后再决定。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "匯入別人分享的設定。預覽後，你可以選擇新增為篩選器，或取代現有的其中一個。"
          }
        }
      }
    },
    "Bring in a setup someone shared. It replaces your blocklists and blocked domains; your allowed exceptions stay put.": {
      "comment": "Intro panel for importing a shared filter. 'setup' = shared configuration; 'blocklists'/'blocked domains'/'allowed exceptions' match catalog. Reassuring.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Übernimm eine Einrichtung, die jemand geteilt hat. Sie ersetzt deine Blocklisten und blockierten Domains; deine erlaubten Ausnahmen bleiben erhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring in a setup someone shared. It replaces your blocklists and blocked domains; your allowed exceptions stay put."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Trae una configuración que alguien compartió. Reemplaza tus listas de bloqueo y dominios bloqueados; tus excepciones permitidas no se tocan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Importez une configuration partagée par quelqu'un. Elle remplace vos listes de blocage et vos domaines bloqués ; vos exceptions autorisées restent en place."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa una configurazione condivisa da qualcuno. Sostituisce le tue liste di blocco e i domini bloccati; le tue eccezioni consentite restano dove sono."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "誰かが共有した設定を取り込みます。ブロックリストとブロック済みドメインが置き換わり、許可した例外はそのまま残ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "누가 공유해 준 설정을 가져와요. 차단 목록과 차단 도메인이 바뀌고, 허용 예외는 그대로 남아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Traga uma configuração que alguém compartilhou. Ela substitui as suas listas de bloqueio e os domínios bloqueados; as suas exceções liberadas continuam."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导入别人分享的配置。它会替换你的拦截列表和已拦截域名；你的允许例外保持不变。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "匯入別人分享的設定。它會取代你的封鎖清單和已封鎖網域；你的允許例外會保留。"
          }
        }
      }
    },
