          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ヒント：集中モードにスケジュールを設定すると、時間帯に応じてフィルターが自動で切り替わります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "팁: 집중 모드에 일정을 설정하면 시간대에 따라 필터가 자동으로 전환됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
