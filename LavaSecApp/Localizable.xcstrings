    "Have a setup to use? Bring it in, or open Settings to fine-tune everything yourself.": {
      "comment": "Localization-gap backfill (was hardcoded in OnboardingFlowView.swift).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Have a setup to use? Bring it in, or open Settings to fine-tune everything yourself."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schon eine Einrichtung parat? Bring sie mit oder öffne die Einstellungen, um alles selbst anzupassen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Tienes una configuración lista? Impórtala, o abre Ajustes para afinarlo todo a tu gusto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez une configuration à utiliser ? Importez-la, ou ouvrez les Réglages pour tout ajuster vous-même."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai una configurazione da usare? Importala, oppure apri le Impostazioni per regolare tutto da te."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "使いたい設定はありますか？読み込むか、設定を開いて自分で細かく調整できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용할 설정이 있나요? 가져오거나, 설정을 열어 직접 세세하게 조정하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Já tem uma configuração para usar? Importe-a ou abra os Ajustes para personalizar tudo do seu jeito."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已有现成的设置？把它导入进来，或打开“设置”自己逐项调整。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已經有一套設定了嗎？把它帶進來，或打開「設定」自己慢慢調。"
          }
        }
      }
    },
