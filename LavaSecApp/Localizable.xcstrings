    "If iOS asks to add a VPN configuration, tap Allow.": {
      "comment": "vpnPermissionPromptMessage static let (AppViewModel:733), surfaced as vpnMessage -> guardPanelMessage -> Text(message.lavaLocalized) at GuardView:110. Catalog-only.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If iOS asks to add a VPN configuration, tap Allow."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn iOS dich bittet, eine VPN-Konfiguration hinzuzufügen, tippe auf „Erlauben“."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si iOS pide añadir una configuración de VPN, toca Permitir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si iOS te demande d'ajouter une configuration VPN, touche Autoriser."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se iOS chiede di aggiungere una configurazione VPN, tocca Consenti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iOSがVPN構成の追加を求めてきたら、「許可」をタップしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS에서 VPN 구성 추가를 요청하면 '허용'을 탭하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
