    "Keep this somewhere safe. It can restore the backup without the password.": {
      "comment": "Release app UI string. Keep product/legal terms from the glossary unchanged and review before final release.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bewahre ihn sicher auf. Damit kannst du das Backup ohne Passwort wiederherstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep this somewhere safe. It can restore the backup without the password."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gardez-le en lieu sûr. Il peut restaurer la sauvegarde sans le mot de passe."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "安全な場所に保管してください。これがあればパスワードなしでもバックアップを復元できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请将它保存在安全位置。没有密码时也可用它恢复备份。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請妥善保存。即使沒有密碼，也能用它復原備份。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guárdalo en un lugar seguro. Permite restaurar la copia de seguridad sin la contraseña."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "안전한 곳에 보관하세요. 비밀번호 없이도 백업을 복원할 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarde isto em um lugar seguro. Ele pode restaurar o backup sem a senha."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Conservalo in un posto sicuro. Può ripristinare il backup anche senza la password."
          }
        }
      }
    },
    "Kept on this iPhone for 7 days, and only leaves the device if you export it or attach it to a bug report.": {
      "comment": "Release app UI string. Keep product/legal terms from the glossary unchanged and review before final release.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wird 7 Tage lang auf diesem iPhone gespeichert und verlässt das Gerät nur, wenn du es exportierst oder an einen Fehlerbericht anhängst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kept on this iPhone for 7 days, and only leaves the device if you export it or attach it to a bug report."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conservé sur cet iPhone pendant 7 jours et ne quitte l’appareil que si vous l’exportez ou le joignez à un rapport de bug."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このiPhoneに7日間保存され、エクスポートするかバグレポートに添付した場合にのみ端末から外部に出ます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在此 iPhone 上保留 7 天，只有当你导出它或将其附加到错误报告时才会离开本机。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在此 iPhone 上保留 7 天，只有當你匯出它或將其附加到錯誤報告時才會離開本機。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se conserva en este iPhone durante 7 días y solo sale del dispositivo si lo exportas o lo adjuntas a un informe de error."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 iPhone에 7일간 보관되며, 직접 내보내거나 버그 신고에 첨부할 때만 기기를 벗어나요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fica neste iPhone por 7 dias e só sai do aparelho se você exportar ou anexar a um relatório de problema."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Conservati su questo iPhone per 7 giorni; lasciano il dispositivo solo se li esporti o li alleghi a una segnalazione."
          }
        }
      }
    },
