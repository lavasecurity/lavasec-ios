        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thank you for your support"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Merci pour votre soutien"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ご支援ありがとうございます"
          }
        },
        "zh-Hans": {
          "stringUnit": {
