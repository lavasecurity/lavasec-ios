        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "感謝你的支持"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gracias por tu apoyo"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "함께해 주셔서 감사해요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Obrigado pelo seu apoio"
          }
        },
        "it": {
