            "state": "translated",
            "value": "Tip: put the Focus on a schedule to switch filters automatically by time of day."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consejo: programa la Concentración para cambiar de filtro automáticamente según la hora del día."
          }
        },
        "fr": {
          "stringUnit": {
