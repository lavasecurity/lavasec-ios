      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Domain-Verlauf und Netzwerkaktivität werden 7 Tage lang aufbewahrt. Zähler und Lava Guard-Fortschritt werden länger aufbewahrt. Unten kannst du jedes behalten oder löschen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
