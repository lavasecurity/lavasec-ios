        }
      }
    },
    "If your DNS provider keeps failing, Lava temporarily uses Device DNS for allowed requests, then switches back when it can.": {
      "comment": "Detail under the 'Fallback to Device DNS' toggle (iOS 26+).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If your DNS provider keeps failing, Lava temporarily uses Device DNS for allowed requests, then switches back when it can."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn dein DNS-Anbieter wiederholt ausfällt, nutzt Lava vorübergehend das Geräte-DNS für erlaubte Anfragen und wechselt zurück, sobald es geht."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si tu proveedor de DNS falla repetidamente, Lava usa temporalmente el DNS del dispositivo para las solicitudes permitidas y vuelve en cuanto puede."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si votre fournisseur DNS échoue à répétition, Lava utilise temporairement le DNS de l'appareil pour les requêtes autorisées, puis revient dès que possible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se il tuo provider DNS continua a non rispondere, Lava usa temporaneamente il DNS del dispositivo per le richieste consentite e torna appena può."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したDNSプロバイダが繰り返し失敗すると、Lavaは許可されたリクエストに一時的にデバイスDNSを使い、可能になり次第戻します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "DNS 제공업체가 반복해서 실패하면 Lava는 허용된 요청에 기기 DNS를 잠시 사용하고, 가능해지면 다시 전환합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se o seu provedor de DNS falha várias vezes, o Lava usa o DNS do dispositivo temporariamente para as solicitações permitidas e volta assim que dá."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果所选 DNS 提供商反复出问题，Lava 会临时用设备 DNS 处理放行的请求，并在可行时切回。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果所選 DNS 提供商一再出問題，Lava 會暫時用裝置 DNS 處理允許的請求，並在可行時切回。"
          }
        }
      }
    },
    "If your DNS provider keeps failing, Lava temporarily uses Device DNS for allowed requests, then switches back when it can. On iOS 17–25 this is best effort.": {
      "comment": "Detail under the 'Fallback to Device DNS' toggle (iOS 17-25 variant).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If your DNS provider keeps failing, Lava temporarily uses Device DNS for allowed requests, then switches back when it can. On iOS 17–25 this is best effort."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn dein DNS-Anbieter wiederholt ausfällt, nutzt Lava vorübergehend das Geräte-DNS für erlaubte Anfragen und wechselt zurück, sobald es geht. Unter iOS 17–25 nach bestem Bemühen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si tu proveedor de DNS falla repetidamente, Lava usa temporalmente el DNS del dispositivo para las solicitudes permitidas y vuelve en cuanto puede. En iOS 17-25 se hace en la medida de lo posible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si votre fournisseur DNS échoue à répétition, Lava utilise temporairement le DNS de l'appareil pour les requêtes autorisées, puis revient dès que possible. Sur iOS 17-25, au mieux possible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se il tuo provider DNS continua a non rispondere, Lava usa temporaneamente il DNS del dispositivo per le richieste consentite e torna appena può. Su iOS 17-25 è al meglio delle possibilità."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したDNSプロバイダが繰り返し失敗すると、Lavaは許可されたリクエストに一時的にデバイスDNSを使い、可能になり次第戻します。iOS 17〜25ではベストエフォートです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "DNS 제공업체가 반복해서 실패하면 Lava는 허용된 요청에 기기 DNS를 잠시 사용하고, 가능해지면 다시 전환합니다. iOS 17~25에서는 최선의 노력으로 작동합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se o seu provedor de DNS falha várias vezes, o Lava usa o DNS do dispositivo temporariamente para as solicitações permitidas e volta assim que dá. No iOS 17-25, isso é feito da melhor forma possível."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果所选 DNS 提供商反复出问题，Lava 会临时用设备 DNS 处理放行的请求，并在可行时切回。在 iOS 17-25 上为尽力而为。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果所選 DNS 提供商一再出問題，Lava 會暫時用裝置 DNS 處理允許的請求，並在可行時切回。在 iOS 17 至 25 上為盡力而為。"
          }
        }
      }
    },
    "If your device's DNS can't be reached, allowed requests briefly use %1$@ over an encrypted connection, then switch back automatically. %2$@ is an outside provider, used only for recovery.": {
      "comment": "OnboardingFlowView:798; selectedProviderName is allow-listed brand (both args same value). Producer edited in codeEdits.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If your device's DNS can't be reached, allowed requests briefly use %1$@ over an encrypted connection, then switch back automatically. %2$@ is an outside provider, used only for recovery."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn das DNS deines Geräts nicht erreichbar ist, laufen erlaubte Anfragen kurz über %1$@ per verschlüsselter Verbindung und wechseln dann automatisch zurück. %2$@ ist ein externer Anbieter, nur zur Wiederherstellung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si no se puede acceder al DNS de tu dispositivo, las solicitudes permitidas usan %1$@ brevemente por una conexión cifrada y luego vuelven automáticamente. %2$@ es un proveedor externo, solo para la recuperación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si le DNS de votre appareil est injoignable, les requêtes autorisées passent brièvement par %1$@ via une connexion chiffrée, puis reviennent automatiquement. %2$@ est un fournisseur externe, utilisé seulement pour la récupération."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se il DNS del dispositivo non è raggiungibile, le richieste consentite usano brevemente %1$@ tramite una connessione cifrata, poi tornano indietro da sole. %2$@ è un provider esterno, usato solo per il ripristino."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスのDNSに接続できない場合、許可されたリクエストは一時的に暗号化された接続で%1$@を使い、その後自動で元に戻ります。%2$@は復旧時のみ使う外部プロバイダです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기의 DNS에 연결할 수 없으면 허용된 요청이 잠시 암호화된 연결로 %1$@을(를) 거친 뒤 자동으로 되돌아갑니다. %2$@은(는) 복구할 때만 쓰는 외부 제공업체입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se o DNS do seu dispositivo não puder ser acessado, as solicitações permitidas usam o %1$@ por um instante em conexão criptografada e depois voltam sozinhas. O %2$@ é um provedor externo, usado só na recuperação."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果无法连接到设备的 DNS，放行的请求会短暂通过加密连接使用 %1$@，随后自动切回。%2$@ 是仅在恢复时使用的外部提供商。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果無法連上你裝置的 DNS，獲允許的請求會短暫透過加密連線使用 %1$@，之後自動切回。%2$@ 是僅在復原時使用的外部供應商。"
          }
        }
      }
    },
    "If your device's DNS stops responding, Lava sends allowed requests to a backup DNS provider, then switches back automatically.": {
      "comment": "Detail under the 'Fallback to alternative DNS' toggle (Device-DNS primary).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If your device's DNS stops responding, Lava sends allowed requests to a backup DNS provider, then switches back automatically."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn das DNS deines Geräts nicht mehr reagiert, sendet Lava erlaubte Anfragen an einen Ersatz-DNS-Anbieter und wechselt dann automatisch zurück."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si el DNS de tu dispositivo deja de responder, Lava envía las solicitudes permitidas a un proveedor de DNS de respaldo y luego vuelve automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si le DNS de votre appareil ne répond plus, Lava envoie les requêtes autorisées vers un fournisseur DNS de secours, puis revient automatiquement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se il DNS del tuo dispositivo smette di rispondere, Lava invia le richieste consentite a un provider DNS di riserva e poi torna indietro da solo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスのDNSが応答しなくなると、Lavaは許可されたリクエストを予備のDNSプロバイダに送り、その後自動で元に戻します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기의 DNS가 응답하지 않으면 Lava는 허용된 요청을 예비 DNS 제공업체로 보내고, 이후 자동으로 되돌아갑니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se o DNS do seu dispositivo para de responder, o Lava envia as solicitações permitidas para um provedor de DNS reserva e depois volta automaticamente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果设备的 DNS 停止响应，Lava 会把放行的请求发送到备用 DNS 提供商，随后自动切回。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果裝置的 DNS 停止回應，Lava 會把允許的請求送往備用 DNS 提供商，之後自動切回。"
          }
        }
      }
    },
