      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your description tells support what to focus on. This is the most useful part of the report."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
