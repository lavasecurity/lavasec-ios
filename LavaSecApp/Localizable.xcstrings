    "This removes the custom blocklist from your saved lists. %@ can be added again later.": {
      "comment": "Release app UI string. %@ is the custom blocklist display name.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch wird die eigene Blockliste aus deinen gespeicherten Listen entfernt. %@ kann später erneut hinzugefügt werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
