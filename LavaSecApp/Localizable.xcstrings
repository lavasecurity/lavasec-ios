    "I understand Lava cannot recover either one.": {
      "comment": "Release app UI string. Keep product/legal terms from the glossary unchanged and review before final release.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich verstehe, dass Lava keines von beiden wiederherstellen kann."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I understand Lava cannot recover either one."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je comprends que Lava ne peut récupérer ni l’un ni l’autre."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava がどちらも復元できないことを理解しています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我明白 Lava 无法恢复其中任何一项。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我了解 Lava 無法復原其中任何一項。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Entiendo que Lava no puede recuperar ninguno de los dos."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava가 둘 다 복구할 수 없다는 점을 이해해요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
