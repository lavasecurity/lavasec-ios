    "Uses the DNS provider from your current Wi-Fi or cellular network. On iOS 17–25 this may not always work.": {
      "comment": "deviceDNSResolverDetailText pre-iOS-26 branch; SettingsView:2161. Catalog-only.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uses the DNS provider from your current Wi-Fi or cellular network. On iOS 17–25 this may not always work."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwendet den DNS-Anbieter aus deinem aktuellen WLAN oder Mobilfunknetz. Unter iOS 17–25 klappt das nicht immer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa el proveedor de DNS de tu red Wi-Fi o de datos actual. En iOS 17-25 puede que no siempre funcione."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilise le fournisseur DNS de votre réseau Wi-Fi ou cellulaire actuel. Sur iOS 17-25, cela ne fonctionne pas toujours."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa il provider DNS della tua rete Wi-Fi o cellulare attuale. Su iOS 17-25 potrebbe non funzionare sempre."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のWi-Fiまたはモバイル通信ネットワークのDNSプロバイダを使用します。iOS 17〜25では常に動作するとは限りません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 Wi-Fi 또는 셀룰러 네트워크의 DNS 제공업체를 사용합니다. iOS 17~25에서는 항상 작동하지는 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa o provedor de DNS da sua rede Wi-Fi ou de celular atual. No iOS 17-25, pode não funcionar sempre."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用当前 Wi-Fi 或蜂窝网络的 DNS 提供商。在 iOS 17-25 上不一定始终有效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用目前 Wi-Fi 或行動網路的 DNS 提供商。在 iOS 17 至 25 上不一定總是有效。"
          }
        }
      }
    },
    "Uses the DNS resolver from the current Wi-Fi or cellular network while Lava still filters locally.": {
      "comment": "deviceDNSResolverDetailText iOS 26 branch; Text(viewModel.deviceDNSResolverDetailText.lavaLocalized) at SettingsView:2161. Catalog-only.",
      "extractionState": "manual",
      "localizations": {
