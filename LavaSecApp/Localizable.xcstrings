    "Looks like you shook your phone. Want to tell us what went wrong?": {
      "comment": "Message in the rage-shake feedback dialog, shown after the user shakes the phone.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sieht aus, als hättest du dein Telefon geschüttelt. Möchtest du uns sagen, was nicht funktioniert hat?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Looks like you shook your phone. Want to tell us what went wrong?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "On dirait que vous avez secoué votre téléphone. Voulez-vous nous dire ce qui n’a pas fonctionné ?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "端末を振ったようです。うまくいかなかった点を教えてもらえますか？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "看起来你摇了摇手机。想告诉我们哪里出问题了吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "看來你搖了一下手機。想告訴我們哪裡出了問題嗎？"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Parece que has agitado el teléfono. ¿Quieres contarnos qué ha pasado?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "휴대폰을 흔드신 것 같아요. 어떤 점이 불편했는지 알려주실래요?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Parece que você balançou o telefone. Quer nos contar o que deu errado?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sembra che tu abbia scosso il telefono. Vuoi dirci cosa non ha funzionato?"
          }
        }
      }
    },
