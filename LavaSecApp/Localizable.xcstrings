    "Add the Lava Switch Filter action, then pick a filter.": {
      "comment": "Automation step 2 in the auto-switch how-to. 'Lava' is the brand name; 'Switch Filter' is the app's Shortcuts action.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge die Lava-Aktion „Filter wechseln“ hinzu und wähle dann einen Filter."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add the Lava Switch Filter action, then pick a filter."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade la acción Cambiar filtro de Lava y luego elige un filtro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez l’action Changer de filtre de Lava, puis choisissez un filtre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi l’azione Cambia filtro di Lava, poi scegli un filtro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「Lava」の「フィルターを切り替え」アクションを追加し、フィルターを選びます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava의 필터 전환 동작을 추가한 다음 필터를 고르세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione a ação Trocar filtro da Lava e depois escolha um filtro."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加 Lava 的“切换筛选器”操作，然后选择一个筛选器。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "加入 Lava 的「切換篩選器」動作，再選擇一個篩選器。"
          }
        }
      }
    },
    "\"If we commit for 12 months, each month is cheaper.\"": {
      "comment": "Jokey plan pitch (testimonial) for the yearly paid monthly subscription offer.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"If we commit for 12 months, each month is cheaper.\""
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Wenn wir uns für 12 Monate festlegen, ist jeder Monat günstiger.“"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«Si nos comprometemos por 12 meses, cada mes sale más barato.»"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Si on s’engage pour 12 mois, chaque mois coûte moins cher. »"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "«Se ci impegniamo per 12 mesi, ogni mese costa meno.»"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「12か月続ける約束なら、毎月が安くなります。」"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "“12개월로 약속하면 매달 더 저렴해요.”"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "“Se nos comprometermos por 12 meses, cada mês fica mais barato.”"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "「如果我们承诺 12 个月，每个月都会更便宜。」"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「如果我們承諾 12 個月，每個月都會更便宜。」"
          }
        }
      }
    },
