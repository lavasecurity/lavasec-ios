    "This enforces the filter and does not route traffic to a server at all": {
      "comment": "Localization-gap backfill (wrapper-localized; was hardcoded in OnboardingFlowView.swift).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This enforces the filter on-device and never sends your traffic to a server."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das setzt den Filter direkt auf dem Gerät durch und sendet deinen Datenverkehr nie an einen Server."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto aplica el filter en el dispositivo y nunca envía tu tráfico a ningún servidor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le filtre est appliqué sur l'appareil et votre trafic n'est jamais envoyé à un serveur."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Applica il filtro e non instrada affatto il traffico verso un server"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フィルターは端末上で適用され、通信がサーバーに送られることは一切ありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "필터를 기기에서 적용하고 트래픽을 서버로 보내지 않아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso aplica o filtro no dispositivo e nunca envia seu tráfego para um servidor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会在设备上执行筛选器，绝不会把你的流量发送到任何服务器。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這會在裝置上套用篩選器，完全不會把你的流量送到伺服器。"
          }
        }
      }
    },
