    "Hey I'm no rock but I take security paw-sonally. U know what I mean?": {
      "comment": "GuardianShieldStyle.settingsDescription .kiwiCreme (SettingsView:2122). Catalog-only.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hey I'm no rock but I take security paw-sonally. U know what I mean?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hey, ich bin kein Stein, aber ich nehme Sicherheit ziemlich pföttlich. Du weißt, was ich meine?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Oye, no soy una simple roca, pero la seguridad me la tomo muy en serio. ¿Me captas?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne suis pas qu'un caillou, mais la sécurité, je la prends à la patte. Tu vois le genre ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ehi, non sono mica una roccia, ma la sicurezza me la prendo a zampe pari. Mi spiego?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ねえ、ただの石じゃないよ。セキュリティは肉球かけて本気だから。わかるよね？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내가 돌멩이는 아니지만 보안은 발바닥까지 진심이라구. 무슨 말인지 알지?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ei, não sou só uma pedra, mas levo a segurança a sério na pata. Saca a ideia?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "嘿，我可不是块石头，但我对安全可是“爪”心爪意。懂我意思吧？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "嘿，我可不是塊石頭，但我把安全當成「喵」上心的大事。懂我意思吧？"
          }
        }
      }
    },
    "Hidden for privacy. Reveal only when you're ready to share.": {
      "comment": "Localization-gap backfill (was hardcoded in ShareableFiltersUI.swift).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hidden for privacy. Reveal only when you're ready to share."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aus Datenschutzgründen verborgen. Zeige ihn erst an, wenn du teilen willst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Oculto por privacidad. Muéstralo solo cuando estés listo para compartir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masqué par confidentialité. Affichez-le seulement quand vous êtes prêt à le partager."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nascosto per la privacy. Mostralo solo quando sei pronto a condividerlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プライバシー保護のため非表示です。共有する準備ができたときだけ表示してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "개인정보 보호를 위해 가려 뒀어요. 공유할 준비가 됐을 때만 표시하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Oculto por privacidade. Mostre apenas quando estiver pronto para compartilhar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为保护隐私已隐藏。准备好分享时再显示。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為保護隱私已隱藏。準備好分享時再顯示。"
          }
        }
      }
    },
