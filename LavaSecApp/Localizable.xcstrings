    "Add a passcode or Face ID so only you can change Lava. Pick which screens ask for it below.": {
      "comment": "Security screen intro panel describing passcode/Face ID lock.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Richte einen Code oder Face ID ein, damit nur du Lava ändern kannst. Unten wählst du, welche Bildschirme danach fragen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a passcode or Face ID so only you can change Lava. Pick which screens ask for it below."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade un código o Face ID para que solo tú puedas cambiar Lava. Abajo eliges qué pantallas lo piden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez un code ou Face ID pour que vous seul puissiez modifier Lava. Choisissez ci-dessous quels écrans le demandent."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi un codice o Face ID così solo tu puoi modificare Lava. Qui sotto scegli quali schermate lo richiedono."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "パスコードか Face ID を設定すれば、Lava を変更できるのはあなただけ。どの画面で確認するかは下で選べます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "암호나 Face ID를 추가하면 당신만 Lava를 바꿀 수 있어요. 어떤 화면에서 물어볼지는 아래에서 고르세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione um código ou o Face ID para que só você possa mudar a Lava. Escolha abaixo quais telas vão pedir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设个密码或 Face ID,只有你能改 Lava。在下方选哪些屏幕需要验证。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "設個密碼或 Face ID，只有你能變更 Lava。下方可選哪些畫面要驗證。"
          }
        }
      }
    },
