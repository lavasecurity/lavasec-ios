    "Tells you when a Focus couldn't switch your filter, for example while editing is locked.": {
      "comment": "Customization → Notifications: helper text for the Filter couldn't switch toggle.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tells you when a Focus couldn't switch your filter, for example while editing is locked."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "編集がロックされている場合など、集中モードがフィルターを切り替えできなかったことをお知らせします。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當「專注模式」無法切換你的篩選器時通知你，例如編輯已鎖定的情況。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当“专注模式”无法切换你的过滤器时通知你，例如编辑已锁定时。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Informiert dich, wenn ein Fokus deinen Filter nicht wechseln konnte, etwa wenn das Bearbeiten gesperrt ist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous prévient lorsqu'un mode de concentration n'a pas pu changer votre filtre, par exemple lorsque la modification est verrouillée."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te avisa cuando un modo de concentración no pudo cambiar tu filtro, por ejemplo cuando la edición está bloqueada."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "예를 들어 편집이 잠겨 있어 집중 모드가 필터를 전환하지 못했을 때 알려줍니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Avisa quando um Foco não conseguiu trocar seu filtro, por exemplo quando a edição está bloqueada."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ti avvisa quando una Full Immersion non riesce a cambiare il filtro, ad esempio quando le modifiche sono bloccate."
          }
        }
      }
    },
    "Tells you when a Focus switches your filter while Lava is closed or in the background.": {
      "comment": "Customization → Notifications: helper text for the Filter changes toggle.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tells you when a Focus switches your filter while Lava is closed or in the background."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Lavaが終了中またはバックグラウンドのときに、集中モードがフィルターを切り替えたことをお知らせします。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當「專注模式」在 Lava 關閉或於背景執行時切換你的篩選器，便通知你。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当“专注模式”在 Lava 关闭或处于后台时切换你的过滤器，会通知你。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Informiert dich, wenn ein Fokus deinen Filter wechselt, während Lava geschlossen ist oder im Hintergrund läuft."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous prévient lorsqu'un mode de concentration change votre filtre alors que Lava est fermée ou en arrière-plan."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te avisa cuando un modo de concentración cambia tu filtro mientras Lava está cerrada o en segundo plano."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Lava가 종료되었거나 백그라운드에 있을 때 집중 모드가 필터를 전환하면 알려줍니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Avisa quando um Foco troca seu filtro enquanto o Lava está fechado ou em segundo plano."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ti avvisa quando una Full Immersion cambia il filtro mentre Lava è chiusa o in background."
          }
        }
      }
    },
    "Thank you for your support": {
