          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden die gespeicherten Zähler für erlaubte und blockierte Anfragen sowie die lokale Schutz-Laufzeit von diesem iPhone entfernt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina de este teléfono los recuentos guardados de elementos permitidos, bloqueados y de tiempo de protección local activa."
          }
