    "Paste the setup code someone shared with you. It usually starts with \"LF1-\".": {
      "comment": "Helper text. Keep the quoted \"LF1-\" prefix exactly as-is and untranslated.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge den Einrichtungscode ein, den jemand mit dir geteilt hat. Er beginnt meist mit \"LF1-\"."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paste the setup code someone shared with you. It usually starts with \"LF1-\"."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pega el código de configuración que alguien compartió contigo. Suele empezar por \"LF1-\"."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Collez le code de configuration que quelqu'un a partagé avec vous. Il commence généralement par \"LF1-\"."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Incolla il codice di configurazione che qualcuno ha condiviso con te. Di solito inizia con \"LF1-\"."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "誰かが共有してくれたセットアップコードを貼り付けてください。通常は \"LF1-\" で始まります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "누군가 공유해 준 설정 코드를 붙여넣으세요. 보통 \"LF1-\"로 시작해요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cole o código de configuração que alguém compartilhou com você. Ele geralmente começa com \"LF1-\"."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "粘贴别人分享给你的设置代码。它通常以 \"LF1-\" 开头。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "貼上別人分享給你的設定代碼。它通常以 \"LF1-\" 開頭。"
          }
        }
      }
    },
