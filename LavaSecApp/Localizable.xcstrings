    "Previous filters are still active. Lava could not reach the source catalog. Check your connection and try again.": {
      "comment": "Release app UI string or runtime format. Preserve placeholders and review before final release.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vorherige Filter sind weiterhin aktiv. Lava konnte den Quellkatalog nicht erreichen. Prüfe deine Verbindung und versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Previous filters are still active. Lava could not reach the source catalog. Check your connection and try again."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les filtres précédents restent actifs. Lava n’a pas pu joindre le catalogue source. Vérifiez votre connexion et réessayez."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "前回のフィルターは引き続き有効です。Lava はソースカタログに接続できませんでした。接続を確認してもう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "之前的过滤器仍在生效。Lava Security 无法连接来源目录。请检查连接后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "先前的篩選器仍在生效。Lava Security 無法連線到來源目錄。請檢查連線後再試一次。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los filtros anteriores siguen activos. Lava no ha podido acceder al catálogo de origen. Comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이전 필터가 계속 사용 중이에요. Lava가 소스 카탈로그에 연결하지 못했어요. 연결을 확인하고 다시 시도하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os filtros anteriores continuam ativos. A Lava não conseguiu acessar o catálogo de origem. Verifique sua conexão e tente de novo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I filtri precedenti sono ancora attivi. Lava non è riuscito a raggiungere il catalogo delle fonti. Controlla la connessione e riprova."
          }
        }
      }
    },
