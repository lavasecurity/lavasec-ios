    "Unlocks your backup right on this iPhone and turns your settings back on. Nothing changes until you tap Restore Backup.": {
      "comment": "Restore screen footer; explains on-device unlock and the Restore Backup confirm step.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entsperrt dein Backup direkt auf diesem iPhone und schaltet deine Einstellungen wieder ein. Nichts ändert sich, bis du auf „Backup wiederherstellen“ tippst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unlocks your backup right on this iPhone and turns your settings back on. Nothing changes until you tap Restore Backup."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloquea tu copia aquí mismo en este iPhone y reactiva tus ajustes. Nada cambia hasta que tocas Restaurar copia de seguridad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déverrouille votre sauvegarde directement sur cet iPhone et réactive vos réglages. Rien ne change tant que vous n'avez pas touché Restaurer la sauvegarde."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sblocca il tuo backup direttamente su questo iPhone e riattiva le tue impostazioni. Non cambia nulla finché non tocchi Ripristina il backup."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存したバックアップをこの iPhone で解除し、設定を元に戻します。「バックアップを復元」をタップするまで何も変わりません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장된 백업을 이 iPhone에서 바로 풀어 설정을 다시 켜요. Restore Backup을 탭하기 전까지는 아무것도 안 바뀌어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueia o seu backup aqui no iPhone e reativa os seus ajustes. Nada muda até você tocar em Restaurar backup."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "直接在这部 iPhone 上解锁备份，并重新开启你的设置。在你点按「恢复备份」前不会有任何改动。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "直接在這支 iPhone 上解鎖備份，並重新開啟你的設定。在你點「復原備份」前不會有任何變更。"
          }
        }
      }
    },
