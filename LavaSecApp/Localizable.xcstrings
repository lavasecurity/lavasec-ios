          }
        }
      }
    },
    "This deletes the signed-in Lava account and its encrypted backup from Lava's servers. Local protection settings stay on this device." : {
      "comment" : "Release app UI string. Keep placeholders and product names intact.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies löscht das angemeldete Lava-Konto und sein verschlüsseltes Backup von Lavas Servern. Lokale Schutzeinstellungen bleiben auf diesem Gerät."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This deletes the signed-in Lava account and its encrypted backup from Lava's servers. Local protection settings stay on this device."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprime le compte Lava connecté et sa sauvegarde chiffrée des serveurs Lava. Les réglages de protection locale restent sur cet appareil."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サインイン中の Lava アカウントと暗号化バックアップを Lava のサーバーから削除します。ローカル保護の設定はこのデバイスに残ります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这会从 Lava Security 服务器删除已登录的 Lava Security 账户及其加密备份。本地防护设置会留在这台设备上。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這會從 Lava Security 伺服器刪除已登入的 Lava Security 帳號及其加密備份。本機防護設定會留在這台裝置上。"
          }
        }
      }
    },
    "This is separate from your account login and is required to decrypt your backup." : {
      "comment" : "Release app UI string. Keep product/legal terms from the glossary unchanged and review before final release.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das ist getrennt von deiner Kontoanmeldung und zum Entschlüsseln deines Backups nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is separate from your account login and is required to decrypt your backup."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "C’est séparé de la connexion au compte et sert à déchiffrer la sauvegarde."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これはアカウントログインとは別で、バックアップの復号に必要です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
