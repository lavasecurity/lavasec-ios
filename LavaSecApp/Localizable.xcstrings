    "New-device restore can use a Passkey or this recovery phrase with your signed-in Lava account": {
      "comment": "Localization-gap backfill (wrapper-localized; was hardcoded in BackupSetupView.swift).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "New-device restore can use a passkey or this recovery phrase with your signed-in Lava account."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auf einem neuen Gerät kannst du mit einem Passkey oder dieser Wiederherstellungsphrase und deinem angemeldeten Lava-Konto wiederherstellen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para restaurar en un nuevo dispositivo puedes usar una clave de acceso o esta frase de recuperación con tu cuenta de Lava."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La restauration sur un nouvel appareil peut utiliser une passkey ou cette phrase de récupération avec votre compte Lava connecté."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il ripristino su un nuovo dispositivo può usare una passkey o questa frase di recupero con il tuo account Lava."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しい端末での復元には、サインイン済みの Lava アカウントでパスキーまたはこのリカバリーフレーズを使えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새 기기 복원은 로그인한 Lava 계정에서 패스키나 이 복구 문구로 할 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Em um novo dispositivo, você pode restaurar com uma passkey ou com esta frase de recuperação na sua conta Lava conectada."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在新设备上恢复时，可使用通行密钥，或在登录 Lava 账户后使用此恢复短语。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在新裝置上復原時，可使用通行密鑰，或搭配已登入的 Lava 帳號使用這組復原片語。"
          }
        }
      }
    },
