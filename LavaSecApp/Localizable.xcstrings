    "Filtering is on using the encrypted DNS fallback because the selected resolver is briefly unavailable": {
      "comment": "Localization-gap backfill (was hardcoded in ProtectionConnectivityPresentation.swift).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Filtering is on using the encrypted DNS backup because your DNS provider is briefly unavailable"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Filter ist aktiv und nutzt das verschlüsselte DNS-Backup, weil dein DNS-Anbieter kurz nicht erreichbar ist"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El filtrado está activo usando el DNS cifrado de reserva porque tu proveedor de DNS no está disponible por un momento"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
