          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提示：为专注模式设置时间安排，即可按一天中的不同时段自动切换过滤器。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
