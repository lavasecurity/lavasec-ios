          }
        }
      }
    },
    "This helps debug missing, stale, or incorrectly compiled filter lists.": {
      "comment": "Bug-report preview section title/purpose (BugReportBundle, shown via .lavaLocalized).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This helps debug missing, stale, or incorrectly compiled filter lists."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das hilft, fehlende, veraltete oder falsch kompilierte Filterlisten zu untersuchen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto ayuda a depurar listas de filtros faltantes, obsoletas o mal compiladas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
