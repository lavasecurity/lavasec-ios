    "This deletes the signed-in Lava account and its encrypted backup from Lava's servers. Local protection settings stay on this device.": {
      "comment": "Release app UI string. Keep placeholders and product names intact.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies löscht das angemeldete Lava-Konto und sein verschlüsseltes Backup von Lavas Servern. Lokale Schutzeinstellungen bleiben auf diesem Gerät."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This deletes the signed-in Lava account and its encrypted backup from Lava's servers. Local protection settings stay on this device."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime le compte Lava connecté et sa sauvegarde chiffrée des serveurs Lava. Les réglages de protection locale restent sur cet appareil."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインイン中の Lava アカウントとその暗号化バックアップを Lava のサーバーから削除します。ローカルの保護設定はこの端末に残ります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会从 Lava 服务器删除已登录的 Lava 账户及其加密备份。本地防护设置会留在这台设备上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這會從 Lava 伺服器刪除已登入的 Lava 帳號及其加密備份。本機防護設定會留在這台裝置上。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina la cuenta de Lava con la que has iniciado sesión y su copia de seguridad cifrada de los servidores de Lava. Los ajustes de protección local permanecen en este dispositivo."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인된 Lava 계정과 그 암호화 백업을 Lava 서버에서 삭제해요. 로컬 보호 설정은 이 기기에 그대로 남아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso exclui a conta Lava conectada e o backup criptografado dela dos servidores da Lava. As configurações de proteção local ficam neste aparelho."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo elimina dai server di Lava l'account Lava con cui hai eseguito l'accesso e il suo backup cifrato. Le impostazioni di protezione locale restano su questo dispositivo."
          }
        }
      }
    },
