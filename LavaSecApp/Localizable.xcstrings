    "These counters help diagnose slow internet, DNS timeouts, resolver failures, and Wi-Fi or cellular handoff issues.": {
      "comment": "Bug-report preview section purpose: Network & Resolver Health.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These counters help diagnose slow internet, DNS timeouts, resolver failures, and Wi-Fi or cellular handoff issues."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Zähler helfen, langsames Internet, DNS-Timeouts, Resolver-Ausfälle sowie Probleme beim Wechsel zwischen WLAN und Mobilfunk zu diagnostizieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estos contadores ayudan a diagnosticar problemas de internet lento, tiempos de espera de DNS, fallos del resolver y traspasos entre Wi-Fi y datos móviles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces compteurs aident à diagnostiquer la lenteur d'Internet, les délais DNS, les échecs du résolveur et les problèmes de transition entre le Wi-Fi et le réseau cellulaire."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questi contatori aiutano a diagnosticare internet lento, timeout DNS, errori del resolver e problemi di passaggio tra Wi-Fi e rete cellulare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これらのカウンターは、インターネットの速度低下、DNS のタイムアウト、リゾルバの失敗、Wi-Fi やモバイル通信の切り替えの問題の診断に役立ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 카운터는 느린 인터넷, DNS 시간 초과, 리졸버 오류, Wi-Fi 또는 셀룰러 전환 문제를 진단하는 데 도움이 됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esses contadores ajudam a diagnosticar internet lenta, tempos limite de DNS, falhas do resolvedor e problemas de transição entre Wi-Fi e rede celular."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这些计数器有助于诊断网速慢、DNS 超时、解析器故障以及 Wi-Fi 或蜂窝网络切换问题。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這些計數有助於診斷網路緩慢、DNS 逾時、解析器故障，以及 Wi-Fi 或行動網路切換的問題。"
          }
        }
      }
    },
