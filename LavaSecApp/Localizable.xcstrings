    "Malicious domains are the hot spots. Your phone can step around them before apps and websites connect.": {
      "comment": "Release app UI string. Keep placeholders and product names intact.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schädliche Domains sind die Gefahrenstellen. Dein Telefon kann ihnen ausweichen, bevor Apps und Websites eine Verbindung aufbauen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Malicious domains are the hot spots. Your phone can step around them before apps and websites connect."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les domaines malveillants, c'est là que ça chauffe. Votre téléphone peut les éviter avant que les apps et les sites web s'y connectent."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "悪意のあるドメインは危険の集まる場所です。アプリやウェブサイトが接続する前に、iPhone がそこを避けてくれます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "恶意域名就像滚烫的岩浆。在 App 和网站连接前，你的手机可以先帮你绕开它们。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "惡意網域就像滾燙的熱點。在 App 與網站連線前，你的手機可以先繞開它們。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los dominios dañinos son los puntos calientes. Tu teléfono puede esquivarlos antes de que las apps y los sitios web se conecten."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "해로운 도메인은 피해야 할 곳이에요. 앱과 웹사이트가 연결되기 전에 휴대폰이 알아서 피해 갈 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os domínios nocivos são os pontos a evitar. O seu telefone pode desviar deles antes que apps e sites se conectem."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I domini dannosi sono i punti caldi. Il tuo telefono può aggirarli prima che app e siti web si colleghino."
          }
        }
      }
    },
