        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": " per usare DNS su HTTPS, TLS e QUIC"
          }
        }
      }
    },
    "Open the Settings app": {
      "comment": "Button in the auto-switch how-to Focus section; opens the iOS Settings app. 'Settings' is the iOS app name.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einstellungen-App öffnen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open the Settings app"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abrir la app Ajustes"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrir l’app Réglages"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri l’app Impostazioni"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「設定」App を開く"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정 앱 열기"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Abrir o app Ajustes"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开“设置”App"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "打開「設定」App"
          }
        }
      }
    },
    "Opens Lava's page in Settings — tap back, then Focus.": {
      "comment": "Caveat under the Focus section's 'Open the Settings app' button. 'Lava' is the brand; 'Settings'/'Focus' are iOS system names.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffnet Lavas Seite in den Einstellungen – tippe zurück, dann Fokus."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Opens Lava's page in Settings — tap back, then Focus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre la página de Lava en Ajustes: toca atrás y luego Concentración."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvre la page de Lava dans Réglages — revenez en arrière, puis Concentration."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apre la pagina di Lava in Impostazioni: tocca indietro, poi Full Immersion."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「設定」内の Lava のページを開きます。戻ってから「集中モード」を選びます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정에서 Lava 페이지를 엽니다. 뒤로 이동한 다음 집중 모드를 선택하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre a página da Lava nos Ajustes — volte e toque em Foco."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开“设置”中 Lava 的页面——返回后选择“专注模式”。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "打開「設定」中 Lava 的頁面——返回後選擇「專注模式」。"
          }
        }
      }
    },
    "Switch filters on a schedule or with a Focus — no taps needed.": {
      "comment": "Description under the auto-switch how-to header. 'Focus' is the iOS system feature.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wechsle Filter nach Zeitplan oder mit einem Fokus – ganz ohne Tippen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Switch filters on a schedule or with a Focus — no taps needed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia de filtro según un horario o con un modo de Concentración, sin tocar nada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Changez de filtre selon un horaire ou avec un mode de concentration, sans rien toucher."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia filtro in base a un orario o con una Full Immersion, senza toccare nulla."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スケジュールや集中モードに合わせて、タップなしでフィルターを切り替えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일정이나 집중 모드에 따라 탭 없이 필터를 전환하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Troque de filtro por horário ou com um Foco — sem toques."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按计划或借助专注模式自动切换筛选器，无需轻点。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "依排程或搭配專注模式自動切換篩選器，無需輕點。"
          }
        }
      }
    },
