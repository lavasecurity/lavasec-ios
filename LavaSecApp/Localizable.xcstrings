    "Each filter is its own set of blocklists. Apply one to make it the filter in effect — your others stay saved.": {
      "comment": "Localization-gap backfill (wrapper-localized; was hardcoded in FiltersView.swift).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Each filter is its own set of blocklists. Apply one to make it the active filter — your others stay saved."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeder Filter ist eine eigene Sammlung von Blocklisten. Wende einen an, um ihn zum aktiven Filter zu machen – deine anderen bleiben gespeichert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada filter es su propio conjunto de blocklists. Aplica uno para que sea el filter en uso; los demás quedan guardados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque filtre a son propre jeu de blocklists. Appliquez-en un pour qu'il devienne le filtre actif — les autres restent enregistrés."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogni filtro ha le sue blocklist. Applicane uno per renderlo il filtro attivo: gli altri restano salvati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各フィルターは、それぞれ独自のブロックリストの組み合わせです。1 つを適用すると使用中のフィルターになり、ほかのフィルターは保存されたままです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "필터마다 고유한 차단 목록 모음이 있어요. 하나를 적용하면 그 필터가 적용 중이 되고, 나머지는 그대로 저장돼요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada filtro é um conjunto próprio de blocklists. Aplique um para deixá-lo em uso — os outros continuam salvos."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每个筛选器都是一组独立的拦截清单。应用某个筛选器即可让它生效——其余的会继续保存。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每個篩選器都是一組獨立的封鎖清單。套用其中一個就會讓它生效，其餘的仍會保留。"
          }
        }
      }
    },
