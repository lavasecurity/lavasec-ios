    "Switch your active Lava filter automatically when a Focus turns on.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Switch your active Lava filter automatically when a Focus turns on."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wechsle deinen aktiven Lava Filter automatisch, sobald ein Fokus aktiv wird."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia tu filtro de Lava activo automáticamente cuando se activa un modo de concentración."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Changez automatiquement votre filtre Lava actif lorsqu’un mode de concentration s’active."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia automaticamente il filtro Lava attivo quando si attiva una Full Immersion."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "集中モードがオンになると、有効な Lava フィルターを自動で切り替えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "집중 모드가 켜지면 적용 중인 Lava 필터를 자동으로 전환해요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Troca automaticamente o filtro da Lava ativo quando um Foco é ativado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当「专注模式」开启时，自动切换当前生效的 Lava 筛选器。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當「專注模式」開啟時，自動切換目前生效的 Lava 篩選器。"
          }
        }
      }
    }
  },
  "version": "1.0"
